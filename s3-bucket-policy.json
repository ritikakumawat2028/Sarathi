# S3 Bucket Policy Template
# Apply this to your S3 bucket so the frontend files are publicly readable by CloudFront.
# Replace YOUR-BUCKET-NAME with your actual S3 bucket name.

{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "PublicReadGetObject",
            "Effect": "Allow",
            "Principal": "*",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::YOUR-BUCKET-NAME/*"
        }
    ]
}
