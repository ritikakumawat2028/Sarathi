PORT=4000
NODE_ENV=production

# ── MongoDB Atlas ──────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sarathi-ai

# ── JWT ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars
JWT_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────
# Set to your CloudFront URL once deployed (no trailing slash)
# Example: https://abc123.cloudfront.net
CLIENT_ORIGIN=https://REPLACE_WITH_CLOUDFRONT_URL

# ── Google Gemini ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-from-aistudio

# ── Government Schemes ─────────────────────────────────────────
DATA_GOV_IN_API_KEY=579b464db66ec23bdd000001cdd3946e44ce4aad7209ff7b23ac571b
MYSCHEME_FETCH_ENABLED=true
SCHEMES_CACHE_TTL_SECONDS=21600
SCHEMES_REFRESH_CRON=15 3 * * *
