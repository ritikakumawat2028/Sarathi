# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Gemini API Key (Get free key from Google AI Studio: https://aistudio.google.com/)
GEMINI_API_KEY=

# --- MongoDB Database ---
# Option 1: Local MongoDB (install from https://www.mongodb.com/try/download/community)
MONGODB_URI=mongodb://localhost:27017/sarathi-ai
# Option 2: MongoDB Atlas (Free tier — create at https://cloud.mongodb.com)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sarathi-ai?retryWrites=true&w=majority

# --- Government data sources ---

# data.gov.in (Open Government Data Platform India)
# Free API key: register at https://data.gov.in -> Sign Up -> "My Account" -> API Key
# Without a key, the public sample key below has very low rate limits and is for testing only.
DATA_GOV_IN_API_KEY=579b464db66ec23bdd000001cdd3946e44ce4aad7209ff7b23ac571b
# Comma-separated list of data.gov.in resource IDs to pull scheme/benefit datasets from.
# Find resource IDs by searching https://www.data.gov.in/ for a dataset and copying the
# resource id from its URL/API section (Ministry-published scheme & scholarship datasets).
DATA_GOV_IN_RESOURCE_IDS=

# myScheme (National Scheme Search platform, MeitY / NeGD) — public search endpoint used by
# the myscheme.gov.in website itself. It is not an officially documented/versioned API, so
# it can change or rate-limit without notice. The backend treats it as best-effort and always
# falls back to cached/seed data if it fails.
MYSCHEME_API_BASE=https://api.myscheme.gov.in/search/v5
MYSCHEME_FETCH_ENABLED=true

# How long fetched scheme data is cached before a refresh is attempted (seconds)
SCHEMES_CACHE_TTL_SECONDS=21600
# Cron expression for the background refresh job (default: every day at 03:15)
SCHEMES_REFRESH_CRON=15 3 * * *
